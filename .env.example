# Copy this file to .env for local overrides.
# .env is gitignored — put real secrets there, never in this file.

# Canonical site origin used in Open Graph tags and the share URL (no trailing slash).
VITE_SITE_URL=https://bubbles.3m4.net

# 3m4 apps index site linked from the footer (no trailing slash).
VITE_INFO_URL=https://info.3m4.net

# Port for the legacy dev server (legacy/scripts/serve.ts).
PORT=8015

# Example secret (fake). Uncomment and set real values in .env only.
#SOME_API_KEY=fake-api-key-123
